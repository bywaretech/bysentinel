{
  "name": "@bysentinel/collector",
  "version": "0.1.0",
  "description": "BySentinel collector and analyzer API",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --watch ./dist/index.js",
    "start": "node ./dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@bysentinel/core": "workspace:*",
    "@bysentinel/providers": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
