# ─── SDK ──────────────────────────────────────────────
BYSENTINEL_COLLECTOR_URL=http://localhost:4000
BYSENTINEL_API_KEY=bsk_local_dev_key
BYSENTINEL_ADMIN_TOKEN=bs_admin_dev_token
BYSENTINEL_PROJECT=payments-api
BYSENTINEL_ENVIRONMENT=development

# ─── AI ───────────────────────────────────────────────
# Defaults used only to bootstrap a fresh data volume. Prefer changing provider,
# model, base URL and API key from the dashboard after login.
BYSENTINEL_AI_ENABLED=false
BYSENTINEL_AI_PROVIDER=openai
BYSENTINEL_AI_MODEL=gpt-4.1-mini
BYSENTINEL_AI_API_KEY=
BYSENTINEL_AI_BASE_URL=
BYSENTINEL_AI_TIMEOUT_MS=20000

# ─── Webhooks ─────────────────────────────────────────
BYSENTINEL_WEBHOOK_SECRET=bswhsec_change_me
BYSENTINEL_WEBHOOK_URLS=
BYSENTINEL_WEBHOOK_TIMEOUT_MS=3000

# ─── Infrastructure ───────────────────────────────────
DATABASE_URL=postgresql://bysentinel:bysentinel@localhost:5432/bysentinel?schema=public
REDIS_URL=redis://localhost:6379

# ─── Dashboard login ──────────────────────────────────
# Default admin account, seeded once on the collector's first boot.
# Change these BEFORE the first install, or sign in and rotate the
# account from the dashboard (Settings > Users) afterwards.
BYSENTINEL_DEFAULT_USER=bysentinel
BYSENTINEL_DEFAULT_PASSWORD=adminbysentinel
DASHBOARD_PORT=4000

# ─── Collector ────────────────────────────────────────
BYSENTINEL_API_KEYS=bsk_local_dev_key
BYSENTINEL_DATA_DIR=./data
COLLECTOR_PORT=4000
COLLECTOR_MAX_BODY_BYTES=262144
COLLECTOR_RATE_LIMIT_PER_MINUTE=120
# Separate, stricter budget for /api/auth/login attempts (per minute).
COLLECTOR_LOGIN_RATE_LIMIT_PER_MINUTE=10
COLLECTOR_CORS_ORIGINS=*

# ─── Security ─────────────────────────────────────────
# When NODE_ENV=production the collector REFUSES to start while the admin token,
# ingest API key or seeded password are still the development defaults above.
# The production compose sets NODE_ENV=production for you.
#   NODE_ENV=production
# Escape hatch (NOT recommended): boot anyway despite insecure defaults.
#   BYSENTINEL_ALLOW_INSECURE_DEFAULTS=true
