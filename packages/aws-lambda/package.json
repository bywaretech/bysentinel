{
  "name": "@bywaretech/bysentinel-aws-lambda",
  "version": "0.1.1",
  "description": "AI Runtime Monitoring SDK for AWS Lambda",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bywaretech/bysentinel.git",
    "directory": "packages/aws-lambda"
  },
  "homepage": "https://github.com/bywaretech/bysentinel/tree/main/packages/aws-lambda#readme",
  "bugs": {
    "url": "https://github.com/bywaretech/bysentinel/issues"
  },
  "keywords": [
    "bysentinel",
    "bywaretech",
    "aws-lambda",
    "lambda",
    "serverless",
    "monitoring",
    "observability",
    "runtime-monitoring",
    "ai-debugging",
    "error-tracking",
    "incident-response",
    "security"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "dependencies": {
    "@bywaretech/bysentinel-core": "workspace:*"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.140",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
