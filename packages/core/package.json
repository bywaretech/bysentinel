{
  "name": "@bywaretech/bysentinel-core",
  "version": "0.1.3",
  "description": "Shared types, redaction/secret-detection engine and fingerprinting for BySentinel",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bywaretech/bysentinel.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bywaretech/bysentinel/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/bywaretech/bysentinel/issues"
  },
  "keywords": [
    "bysentinel",
    "bywaretech",
    "observability",
    "monitoring",
    "redaction",
    "secret-detection",
    "pii",
    "security",
    "fingerprint",
    "incident-analysis",
    "ai-analysis"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo coverage"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
